# F-List login credentials for the ticket request (see connection/ticketClient.ts).
# This is the ACCOUNT you log into f-list.net with - not a character name.
# One account can own many characters; FLIST_CHARACTER below picks which one is the bot.
# Never commit the real .env file.
FLIST_ACCOUNT=
FLIST_PASSWORD=

# Which of that account's characters the bot logs in and acts as (sent separately from
# FLIST_ACCOUNT in the IDN handshake). Must be an existing character on FLIST_ACCOUNT.
FLIST_CHARACTER=

# Identifies this client to the F-Chat server (sent as cname/cversion in IDN).
CLIENT_NAME=FChatBot
CLIENT_VERSION=0.1.0

# Comma-separated character names that are bot admins from the moment the bot starts,
# regardless of what is stored in the database. This is the recovery mechanism if the
# database is ever lost or corrupted - you can never be locked out of your own bot.
BOOTSTRAP_ADMINS=

# Comma-separated room:character pairs granting room-scoped moderator rights at startup.
# Room can be a raw ADH- code, or pasted as [session=Title]adh-xxxx[/session].
# Example: BOOTSTRAP_MODS=adh-1234567890abcdef1234:SomeCharacter,adh-abcdef1234567890abcd:OtherCharacter
BOOTSTRAP_MODS=

# pino log level: trace|debug|info|warn|error|fatal
LOG_LEVEL=info

# Where the SQLite database and per-room chat logs are written.
DATA_DIR=./data

# Where plugin folders are scanned from.
PLUGIN_DIR=./plugins
